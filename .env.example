# =============================================================================
# Puls-Events RAG - Variables d'environnement
# =============================================================================
# 1. Copier ce fichier en `.env` :   cp .env.example .env
# 2. Remplir les valeurs ci-dessous
# 3. Le fichier .env est dans .gitignore, ne sera jamais committé
# =============================================================================

# --- API Mistral ---
# Obtenir une clé sur https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=votre_cle_api_ici

# --- API OpenAgenda (optionnel selon la source de données choisie) ---
# Obtenir une clé sur https://openagenda.com/
OPENAGENDA_API_KEY=votre_cle_openagenda_ici

# --- Périmètre du POC ---
TARGET_REGION=ile-de-france
MAX_EVENT_AGE_DAYS=365
